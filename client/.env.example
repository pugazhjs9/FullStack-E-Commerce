# =============================================================================
# client/.env.example
# Copy this file to .env.local and fill in your values.
# In Vite, only variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# ─── API ──────────────────────────────────────────────────────────────────────

# Backend API base URL.
# Leave empty to use Vite's proxy (recommended for local development).
# Set to your server URL in production.
VITE_API_URL=

# ─── App ──────────────────────────────────────────────────────────────────────

# Application title (used in page titles and meta tags)
# VITE_APP_TITLE=ShopSmart

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Enable debug logging in the browser console (development only)
# VITE_DEBUG=false
