# =============================================================================
# server/.env.example
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ─── Server ───────────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=5001

# Node environment: 'development' | 'production' | 'test'
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS.
# In production, set to your actual frontend domain.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Data Storage ─────────────────────────────────────────────────────────────

# Directory where JSON data files are stored (relative to server root).
# Defaults to src/data if not set.
# DATA_DIR=src/data

# ─── Security (Future) ────────────────────────────────────────────────────────

# Secret used to sign JWT tokens (add when migrating from simple tokens).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=your_very_long_random_secret_here

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info
